{
  "name": "Arch Desktop (soar-3dc)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3000, 3001],
  "portsAttributes": {
    "3000": {
      "label": "Linux desktop (Arch KDE)",
      "onAutoForward": "openPreview"
    },
    "3001": {
      "label": "Ubuntu desktop https",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh && docker pull lscr.io/linuxserver/webtop:arch-kde || true",
  "postStartCommand": "bash .devcontainer/start-desktop.sh",
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb"
  }
}
